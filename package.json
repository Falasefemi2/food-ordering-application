{
	"name": "chowdeck-assignment",
	"module": "index.ts",
	"type": "module",
	"private": true,
	"scripts": {
		"prepare": "husky && effect-language-service patch",
		"test": "vitest run",
		"test:watch": "vitest",
		"check": "biome check --write .",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:push": "drizzle-kit push",
		"db:studio": "drizzle-kit studio",
		"build": "bun build ./index.ts --outdir ./dist --target bun",
		"migrate": "bun --env-file=../../.env run src/schema/migrate.ts",
		"type-check": "tsc --noEmit"
	},
	"dependencies": {
		"@effect/platform-bun": "^4.0.0-beta.88",
		"@effect/platform-node": "^4.0.0-beta.88",
		"@effect/sql-pg": "4.0.0-beta.85",
		"@types/pg": "^8.20.0",
		"argon2": "^0.44.0",
		"dotenv": "^17.4.2",
		"drizzle-kit": "1.0.0-rc.2",
		"drizzle-orm": "1.0.0-rc.2",
		"effect": "4.0.0-beta.85",
		"jose": "^6.0.11",
		"pg": "^8.22.0"
	},
	"devDependencies": {
		"@changesets/cli": "^2.31.0",
		"@effect/language-service": "^0.86.2",
		"@effect/vitest": "4.0.0-beta.85",
		"@types/bun": "latest",
		"husky": "^9.1.7",
		"lint-staged": "^17.0.4",
		"oxlint": "^1.64.0",
		"prettier": "^3.8.3",
		"typescript": "^6.0.3",
		"vitest": "^4.1.6"
	},
	"peerDependencies": {
		"typescript": "^5.4.0"
	},
	"lint-staged": {
		"*.{ts,tsx}": [
			"oxlint --fix",
			"prettier --write"
		],
		"*.{json,md,yml,yaml}": [
			"prettier --write"
		]
	}
}
